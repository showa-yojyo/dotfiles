{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "accent_color": "#ff1493",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "template": " \uf0e7 ",
          "foreground": "#000000",
          "powerline_symbol": "\ue0b0",
          "background": "#ffc0b0",
          "type": "root",
          "style": "powerline"
        },
        {
          "options": {
            "display_root": true,
            "folder_icon": "\uf115",
            "folder_separator_icon": "/",
            "style": "agnoster_full"
          },
          "template": "{{ .Path }}",
          "foreground": "#000000",
          "powerline_symbol": "\ue0b0",
          "background": "#ffb6c1",
          "type": "path",
          "style": "powerline"
        },
        {
          "options": {
            "cache_duration": "none",
            "fetch_stash_count": true,
            "fetch_status": true,
            "fetch_upstream_icon": true,
            "untracked_modes": {}
          },
          "templates": [
            "{{ .UpstreamIcon }}{{ .HEAD }}",
            "{{ if .BranchStatus }} {{ .BranchStatus }}{{ end }}",
            "{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}",
            "{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}",
            "{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}",
            "{{ if gt .StashCount 0 }} \uf692 {{ .StashCount }}{{ end }}"
          ],
          "foreground": "#000000",
          "powerline_symbol": "\ue0b0",
          "background": "#ff69b4",
          "type": "git",
          "style": "powerline"
        },
        {
          "options": {
            "cache_duration": "none",
            "display_mode": "context"
          },
          "template": "{{ .Full }}",
          "foreground": "#ffffff",
          "powerline_symbol": "\ue0b0",
          "background": "#ff1493",
          "type": "python",
          "style": "powerline"
        },
        {
          "options": {
            "cache_duration": "none",
            "display_mode": "files",
            "fetch_version": true
          },
          "template": "\ue718{{ .Full }}",
          "foreground": "#ffffff",
          "powerline_symbol": "\ue0b0",
          "background": "#6CA35E",
          "type": "node",
          "style": "powerline"
        },
        {
          "options": {
            "cache_duration": "none",
            "display_mode": "files",
            "fetch_version": true
          },
          "template": "\ue791{{ .Full }}",
          "foreground": "#ffffff",
          "powerline_symbol": "\ue0b0",
          "background": "#cc342d",
          "type": "ruby",
          "style": "powerline"
        },
        {
          "template": "exit {{ .Code }}",
          "foreground": "#ffffff",
          "powerline_symbol": "\ue0b0",
          "background": "#f10000",
          "type": "exit",
          "style": "powerline"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "options": {
            "threshold": 500
          },
          "template": "\uf608{{ .FormattedMs }}",
          "foreground": "#fefefe",
          "powerline_symbol": "\ue0b2",
          "type": "executiontime",
          "style": "plain",
          "invert_powerline": true
        },
        {
          "options": {
            "time_format": "15:04:05 JST+9:00"
          },
          "template": "\uf64f{{ dateInZone .Format .CurrentDate \"Asia/Tokyo\" }}",
          "foreground": "#fefefe",
          "type": "time",
          "style": "plain",
          "invert_powerline": true
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "template": "{{ if eq .Shell \"bash\" }}{{ .Env.CURRENT_HISTORY_NUMBER }} ${{ else if eq .Shell \"pwsh\" }}PS >{{ end }}",
          "foreground": "#ffffff",
          "type": "text",
          "style": "plain"
        }
      ],
      "newline": true
    }
  ],
  "final_space": true,
  "terminal_background": "#ffc0b0",
  "version": 4
}
