# .inputrc: readline initialization file.

# HINT: To source this settings, press C-x C-r or execute:
# bind -f ~/.inputrc

# Be 8 bit clean.
set input-meta on
set output-meta on

# To allow the use of 8bit-characters like the german umlauts, uncomment
# the line below. However this makes the meta key not work as a meta key,
# which is annoying to those which don't need to type in 8-bit characters.
set convert-meta off

# try to enable the application keypad when it is called.  Some systems
# need this to enable the arrow keys.
# set enable-keypad on

# see /usr/share/doc/bash/inputrc.arrows for other codes of arrow keys

# do not bell on tab-completion
set bell-style none
# set bell-style visible

# some defaults / modifications for the emacs mode
$if mode=emacs

  # allow the use of the Home/End keys
  "\e[1~": beginning-of-line
  "\e[4~": end-of-line

  # allow the use of the Delete/Insert keys
  "\e[3~": delete-char
  "\e[2~": quoted-insert

  # mappings for "page up" and "page down" to step to the beginning/end
  # of the history
  # "\e[5~": beginning-of-history
  # "\e[6~": end-of-history

  # alternate mappings for "page up" and "page down" to search the history
  # "\e[5~": history-search-backward
  # "\e[6~": history-search-forward

  # mappings for Ctrl-left-arrow and Ctrl-right-arrow for word moving
  "\e[1;5C": forward-word
  "\e[1;5D": backward-word
  "\e[5C": forward-word
  "\e[5D": backward-word
  "\e\e[C": forward-word
  "\e\e[D": backward-word

  $if term=rxvt
    "\e[7~": beginning-of-line
    "\e[8~": end-of-line
    "\eOc": forward-word
    "\eOd": backward-word
  $endif

  # for non RH/Debian xterm, can't hurt for RH/Debian xterm
  # "\eOH": beginning-of-line
  # "\eOF": end-of-line

  # for freebsd console
  # "\e[H": beginning-of-line
  # "\e[F": end-of-line

  ## Customize key bindings.
  set keymap emacs-ctlx

  # C-x m bindings are for memory management
  "md": "sudo ~/.local/bin/wsl-drop-cache\C-m"
  "mf": "free -ht\C-m"

  # C-x g bindings are for Git operations
  "ga": "git add "
  "gc": "git commit -m \"\"\C-b"
  "gd": "git diff "
  "gp": "git push || git push --force-with-lease\C-m"

  # fzg-git.sh bindings
  # \e[0n: redraw-current-line
  "gb": " \C-u \C-a\C-k`_fzf_git_branches`\e\C-e\C-y\C-a\C-y\ey\C-h\C-e\e[0n \C-h"
  "ge": " \C-u \C-a\C-k`_fzf_git_each_ref`\e\C-e\C-y\C-a\C-y\ey\C-h\C-e\e[0n \C-h"
  "gf": " \C-u \C-a\C-k`_fzf_git_files`\e\C-e\C-y\C-a\C-y\ey\C-h\C-e\e[0n \C-h"
  "gh": " \C-u \C-a\C-k`_fzf_git_hashes`\e\C-e\C-y\C-a\C-y\ey\C-h\C-e\e[0n \C-h"
  "gl": " \C-u \C-a\C-k`_fzf_git_lreflogs`\e\C-e\C-y\C-a\C-y\ey\C-h\C-e\e[0n \C-h"
  "gr": " \C-u \C-a\C-k`_fzf_git_remotes`\e\C-e\C-y\C-a\C-y\ey\C-h\C-e\e[0n \C-h"
  "gs": " \C-u \C-a\C-k`_fzf_git_stashes`\e\C-e\C-y\C-a\C-y\ey\C-h\C-e\e[0n \C-h"
  "gt": " \C-u \C-a\C-k`_fzf_git_tags`\e\C-e\C-y\C-a\C-y\ey\C-h\C-e\e[0n \C-h"
  "gw": " \C-u \C-a\C-k`_fzf_git_worktrees`\e\C-e\C-y\C-a\C-y\ey\C-h\C-e\e[0n \C-h"
$endif

$if Bash

  # Attempt to briefly move the cursor to an opening parenthesis when a closing
  # parenthesis is inserted.
  set blink-matching-paren on

  # Display the common prefix of the set of possible completions using a
  # different color when listing completions.
  set colored-completion-prefix on

  # Display possible completions using different colors to indicate their file
  # type. See also visible-stats.
  set colored-stats on

  # The string that is inserted when the insert-comment command is executed.
  set comment-begin "#"

  #set completion-display-width -1

  # Make readline perform filename matching and completion in a
  # case-insensitive fashion.
  set completion-ignore-case on

  # Identify hyphens and underscores?
  # See also completion-ignore-case.
  set completion-map-case on

  # The length in characters of the common prefix of a list of possible
  # completions that is displayed without modification.
  set completion-prefix-display-length 2

  # Determine when the user is queried about viewing the number of possible
  # completions generated by the possible-completions command.
  set completion-query-items 80

  #set enable-keypad on
  #set enable-meta-key on

  # Expand homedir name
  #set expand-tilde off

  #set history-preserve-point off
  #set history-size 500
  #set horizontal-scroll-mode off

  # The duration readline will wait for a character when reading an ambiguous
  # key sequence.
  set keyseq-timeout 50

  # Append "/" to all dirnames
  set mark-directories on
  set mark-modified-lines on
  set mark-symlinked-directories on

  # Match all files
  #set match-hidden-files on

  #set page-completions on
  #set print-completions-horizontally off
  #set revert-all-at-newline off

  set show-all-if-ambiguous off
  set show-all-if-unmodified off
  #set show-mode-in-prompt off
  #set skip-completed-text off

  # Append a character denoting a file's type as reported by stat(2) to the
  # filename when listing possible completions.
  set visible-stats on

  # 'Magic Space'
  # Insert a space character then performs
  # a history expansion in the line
  #Space: magic-space

  #Tab: menu-complete
$endif
